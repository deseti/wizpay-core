generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model Task {
  id           String            @id @default(uuid()) @db.Uuid
  type         String
  status       String
  totalUnits   Int               @default(0)
  completedUnits Int             @default(0)
  failedUnits  Int               @default(0)
  metadata     Json?
  payload      Json
  result       Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  logs         TaskLog[]
  units        TaskUnit[]
  transactions TaskTransaction[]
}

model TaskLog {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @db.Uuid
  level     String   @default("INFO")
  step      String
  status    String
  message   String
  context   Json?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskUnit {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @db.Uuid
  type      String
  index     Int
  status    String   @default("PENDING")
  txHash    String?
  error     String?
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@unique([taskId, id])
  @@unique([taskId, index])
}

/// Tracks individual on-chain transactions within a task.
/// Each payroll recipient gets one TaskTransaction record.
model TaskTransaction {
  id          String   @id @default(uuid()) @db.Uuid
  taskId      String   @db.Uuid
  /// Circle transaction ID
  txId        String
  /// Recipient address
  recipient   String
  /// Human-readable amount
  amount      String
  /// Token symbol (USDC, EURC)
  currency    String
  /// pending | completed | failed
  status      String   @default("pending")
  /// On-chain tx hash (null until confirmed)
  txHash      String?
  /// Error reason (only for failed transactions)
  errorReason String?
  /// Batch index within the payroll
  batchIndex  Int      @default(0)
  /// Number of poll attempts made
  pollAttempts Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([txId])
  @@index([taskId, status])
}

model UserWallet {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String
  userEmail   String?
  chain       String
  blockchain  String
  walletId    String   @unique
  address     String
  walletSetId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, chain])
  @@unique([userId, blockchain])
}

model AppWalletSwapOperation {
  operationId              String   @id @db.Uuid
  operationMode            String
  sourceChain              String
  tokenIn                  String
  tokenOut                 String
  amountIn                 String
  userWalletAddress        String
  treasuryDepositAddress   String
  expectedOutput           Json?
  minimumOutput            Json?
  expiresAt                String
  status                   String
  quoteId                  Json?
  rawQuote                 Json?
  depositTxHash            String?
  circleTransactionId      String?
  circleReferenceId        String?
  circleWalletId           String?
  depositSubmittedAt       DateTime?
  depositConfirmedAt       DateTime?
  depositConfirmedAmount   String?
  depositConfirmationError String?
  executionEnabled         Boolean  @default(false)
  treasurySwapId           String?
  treasurySwapQuoteId      String?
  treasurySwapTxHash       String?
  treasurySwapSubmittedAt  DateTime?
  treasurySwapConfirmedAt  DateTime?
  treasurySwapExpectedOutput Json?
  treasurySwapActualOutput String?
  rawTreasurySwap          Json?
  payoutTxHash             String?
  payoutAmount             String?
  payoutSubmittedAt        DateTime?
  payoutConfirmedAt        DateTime?
  rawPayout                Json?
  completedAt              DateTime?
  executionError           String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([status])
  @@index([circleTransactionId])
  @@index([circleReferenceId])
  @@index([depositTxHash])
  @@index([treasurySwapId])
  @@index([treasurySwapTxHash])
  @@index([payoutTxHash])
}

model BridgeTransaction {
  id            String   @id @default(uuid())
  taskId        String   @unique
  status        String
  payload       Json
  result        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
