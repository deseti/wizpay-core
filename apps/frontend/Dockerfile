# syntax=docker/dockerfile:1.7

FROM node:20-alpine AS builder

WORKDIR /app

ENV NEXT_TELEMETRY_DISABLED=1 \
		npm_config_fetch_retries=5 \
		npm_config_fetch_retry_factor=2 \
		npm_config_fetch_retry_mintimeout=20000 \
		npm_config_fetch_retry_maxtimeout=120000 \
		npm_config_fetch_timeout=300000

COPY package.json package-lock.json ./
RUN --mount=type=cache,target=/root/.npm \
		attempt=1; \
		until npm install --legacy-peer-deps --no-audit --no-fund --prefer-offline; do \
			if [ "$attempt" -ge 3 ]; then \
				echo "npm install failed after $attempt attempts"; \
				exit 1; \
			fi; \
			echo "npm install failed on attempt $attempt, retrying..."; \
			attempt=$((attempt + 1)); \
			npm cache verify || true; \
		done

COPY . .

# ── Build-time env vars ───────────────────────────────────────────────────────
# Each ARG receives its value from docker-compose build.args (which reads from
# root .env). The ENV lines bake the values into the Next.js bundle so they are
# available as process.env.NEXT_PUBLIC_* in browser code.
#
# To add a new public var: add ARG + ENV here AND in docker-compose build.args
# AND in the root .env file.
ARG NEXT_PUBLIC_API_URL=http://localhost:4000
ARG NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:4000
ARG NEXT_PUBLIC_BACKEND_URL=
ARG NEXT_PUBLIC_GOOGLE_CLIENT_ID=
ARG NEXT_PUBLIC_CIRCLE_APP_ID=
ARG NEXT_PUBLIC_CIRCLE_KIT_KEY=
ARG NEXT_PUBLIC_CIRCLE_PASSKEY_CLIENT_KEY=
ARG NEXT_PUBLIC_CIRCLE_PASSKEY_CLIENT_URL=
ARG NEXT_PUBLIC_CIRCLE_PASSKEY_MODULAR_RPC_URL_ARC_TESTNET=
ARG NEXT_PUBLIC_CIRCLE_PASSKEY_MODULAR_RPC_URL_ETH_SEPOLIA=
ARG NEXT_PUBLIC_CIRCLE_PASSKEY_RP_ID=app.wizpay.xyz
ARG NEXT_PUBLIC_RPC_URL=
ARG NEXT_PUBLIC_ARC_TESTNET_RPC_URL=
ARG NEXT_PUBLIC_ARC_TESTNET_RPC_URLS=
ARG NEXT_PUBLIC_ETHEREUM_SEPOLIA_RPC_URL=
ARG NEXT_PUBLIC_ETHEREUM_SEPOLIA_RPC_URLS=
ARG NEXT_PUBLIC_USE_REAL_STABLEFX=false
ARG NEXT_PUBLIC_CIRCLE_API_PROXY_ENABLED=false
ARG NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
ARG NEXT_PUBLIC_ARC_USDC=
ARG NEXT_PUBLIC_ANS_ROOT_REGISTRY=
ARG NEXT_PUBLIC_ANS_REGISTRY=
ARG NEXT_PUBLIC_ANS_RESOLVER=
ARG NEXT_PUBLIC_ANS_FACTORY=
ARG NEXT_PUBLIC_ANS_ARC_REGISTRAR=
ARG NEXT_PUBLIC_ANS_ARC_CONTROLLER=
ARG NEXT_PUBLIC_ANS_PLATFORM_VAULT=
ARG NEXT_PUBLIC_ANS_WIZPAY_REGISTRAR=
ARG NEXT_PUBLIC_ANS_WIZPAY_CONTROLLER=
ARG NEXT_PUBLIC_ANS_WIZPAY_VAULT=
ARG NEXT_PUBLIC_CONTRACT_ADDRESS=
ARG NEXT_PUBLIC_WIZPAY_ADDRESS=
ARG NEXT_PUBLIC_WIZPAY_AGENTIC_NANO_ADDRESS=
# Feature flags
ARG NEXT_PUBLIC_WIZPAY_BRIDGE_EXTERNAL_ENABLED=false

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_BACKEND_API_BASE_URL=$NEXT_PUBLIC_BACKEND_API_BASE_URL
ENV NEXT_PUBLIC_BACKEND_URL=$NEXT_PUBLIC_BACKEND_URL
ENV NEXT_PUBLIC_GOOGLE_CLIENT_ID=$NEXT_PUBLIC_GOOGLE_CLIENT_ID
ENV NEXT_PUBLIC_CIRCLE_APP_ID=$NEXT_PUBLIC_CIRCLE_APP_ID
ENV NEXT_PUBLIC_CIRCLE_KIT_KEY=$NEXT_PUBLIC_CIRCLE_KIT_KEY
ENV NEXT_PUBLIC_CIRCLE_PASSKEY_CLIENT_KEY=$NEXT_PUBLIC_CIRCLE_PASSKEY_CLIENT_KEY
ENV NEXT_PUBLIC_CIRCLE_PASSKEY_CLIENT_URL=$NEXT_PUBLIC_CIRCLE_PASSKEY_CLIENT_URL
ENV NEXT_PUBLIC_CIRCLE_PASSKEY_MODULAR_RPC_URL_ARC_TESTNET=$NEXT_PUBLIC_CIRCLE_PASSKEY_MODULAR_RPC_URL_ARC_TESTNET
ENV NEXT_PUBLIC_CIRCLE_PASSKEY_MODULAR_RPC_URL_ETH_SEPOLIA=$NEXT_PUBLIC_CIRCLE_PASSKEY_MODULAR_RPC_URL_ETH_SEPOLIA
ENV NEXT_PUBLIC_CIRCLE_PASSKEY_RP_ID=$NEXT_PUBLIC_CIRCLE_PASSKEY_RP_ID
ENV NEXT_PUBLIC_RPC_URL=$NEXT_PUBLIC_RPC_URL
ENV NEXT_PUBLIC_ARC_TESTNET_RPC_URL=$NEXT_PUBLIC_ARC_TESTNET_RPC_URL
ENV NEXT_PUBLIC_ARC_TESTNET_RPC_URLS=$NEXT_PUBLIC_ARC_TESTNET_RPC_URLS
ENV NEXT_PUBLIC_ETHEREUM_SEPOLIA_RPC_URL=$NEXT_PUBLIC_ETHEREUM_SEPOLIA_RPC_URL
ENV NEXT_PUBLIC_ETHEREUM_SEPOLIA_RPC_URLS=$NEXT_PUBLIC_ETHEREUM_SEPOLIA_RPC_URLS
ENV NEXT_PUBLIC_USE_REAL_STABLEFX=$NEXT_PUBLIC_USE_REAL_STABLEFX
ENV NEXT_PUBLIC_CIRCLE_API_PROXY_ENABLED=$NEXT_PUBLIC_CIRCLE_API_PROXY_ENABLED
ENV NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=$NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID
ENV NEXT_PUBLIC_ARC_USDC=$NEXT_PUBLIC_ARC_USDC
ENV NEXT_PUBLIC_ANS_ROOT_REGISTRY=$NEXT_PUBLIC_ANS_ROOT_REGISTRY
ENV NEXT_PUBLIC_ANS_REGISTRY=$NEXT_PUBLIC_ANS_REGISTRY
ENV NEXT_PUBLIC_ANS_RESOLVER=$NEXT_PUBLIC_ANS_RESOLVER
ENV NEXT_PUBLIC_ANS_FACTORY=$NEXT_PUBLIC_ANS_FACTORY
ENV NEXT_PUBLIC_ANS_ARC_REGISTRAR=$NEXT_PUBLIC_ANS_ARC_REGISTRAR
ENV NEXT_PUBLIC_ANS_ARC_CONTROLLER=$NEXT_PUBLIC_ANS_ARC_CONTROLLER
ENV NEXT_PUBLIC_ANS_PLATFORM_VAULT=$NEXT_PUBLIC_ANS_PLATFORM_VAULT
ENV NEXT_PUBLIC_ANS_WIZPAY_REGISTRAR=$NEXT_PUBLIC_ANS_WIZPAY_REGISTRAR
ENV NEXT_PUBLIC_ANS_WIZPAY_CONTROLLER=$NEXT_PUBLIC_ANS_WIZPAY_CONTROLLER
ENV NEXT_PUBLIC_ANS_WIZPAY_VAULT=$NEXT_PUBLIC_ANS_WIZPAY_VAULT
ENV NEXT_PUBLIC_CONTRACT_ADDRESS=$NEXT_PUBLIC_CONTRACT_ADDRESS
ENV NEXT_PUBLIC_WIZPAY_ADDRESS=$NEXT_PUBLIC_WIZPAY_ADDRESS
ENV NEXT_PUBLIC_WIZPAY_AGENTIC_NANO_ADDRESS=$NEXT_PUBLIC_WIZPAY_AGENTIC_NANO_ADDRESS
ENV NEXT_PUBLIC_WIZPAY_BRIDGE_EXTERNAL_ENABLED=$NEXT_PUBLIC_WIZPAY_BRIDGE_EXTERNAL_ENABLED

RUN npm run build

FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000

CMD ["node", "server.js"]